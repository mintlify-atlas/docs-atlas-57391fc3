  "keyFeatures": [
    "N-dimensional tensors with automatic differentiation",
    "DataFrame and Series for tabular data",
    "90+ tensor operations with broadcasting",
    "Classical ML models (Linear, Tree-based, SVM, KNN, Naive Bayes)",
    "Neural network layers (Linear, Conv, RNN, LSTM, GRU, Attention)",
    "Optimizers (SGD, Adam, AdamW, RMSprop) with LR schedulers",
    "Linear algebra operations (SVD, QR, LU, Cholesky, Eigenvalue)",
    "Statistical functions and hypothesis tests",
    "Data preprocessing (scalers, encoders, cross-validation)",
    "40+ ML metrics for classification, regression, clustering",
    "Built-in datasets and synthetic generators",
    "SVG/PNG plotting with ML visualization support"
  ],
  "publicApiSurface": [
    "tensor, zeros, ones, arange, linspace, eye, full, empty",
    "add, sub, mul, div, matmul, dot, pow, sqrt, exp, log",
    "parameter, GradTensor, noGrad, backward",
