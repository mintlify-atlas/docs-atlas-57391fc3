    "LinearRegression, Ridge, Lasso, LogisticRegression",
    "DecisionTreeClassifier, DecisionTreeRegressor, RandomForestClassifier, RandomForestRegressor",
    "GradientBoostingClassifier, GradientBoostingRegressor",
    "KMeans, DBSCAN, PCA, TSNE",
    "KNeighborsClassifier, KNeighborsRegressor, LinearSVC, LinearSVR, GaussianNB",
    "Sequential, Linear, Conv1d, Conv2d, RNN, LSTM, GRU",
    "MultiheadAttention, TransformerEncoderLayer",
    "ReLU, Sigmoid, Tanh, GELU, Softmax, Dropout, BatchNorm1d, LayerNorm",
    "mseLoss, maeLoss, crossEntropyLoss, binaryCrossEntropyLoss, huberLoss",
    "SGD, Adam, AdamW, Nadam, RMSprop, Adagrad, AdaDelta",
    "StepLR, MultiStepLR, ExponentialLR, CosineAnnealingLR, OneCycleLR, ReduceLROnPlateau",
    "StandardScaler, MinMaxScaler, RobustScaler, LabelEncoder, OneHotEncoder",
    "trainTestSplit, KFold, StratifiedKFold",
    "accuracy, precision, recall, f1Score, rocAucScore, confusionMatrix",
    "meanSquaredError, meanAbsoluteError, r2Score",
    "svd, qr, lu, cholesky, eig, eigh, inv, pinv, det, solve, lstsq",
    "mean, median, mode, variance, std, skewness, kurtosis, quantile",
    "pearsonr, spearmanr, kendalltau, corrcoef, cov",
